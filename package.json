{
  "name": "code-review",
  "displayName": "Code Review",
  "description": "Structured Copilot-powered code review in a table view.",
  "version": "1.0.0",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codeReview.runReview",
    "onCommand:codeReview.applyFixes",
    "onCommand:codeReview.authenticate"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeReview.runReview",
        "title": "Code Review: Review",
        "icon": "$(checklist)"
      },
      {
        "command": "codeReview.applyFixes",
        "title": "Code Review: Apply fixes from last review",
        "icon": "$(wand)"
      },
      {
        "command": "codeReview.authenticate",
        "title": "Code Review: Authenticate Copilot",
        "icon": "$(account)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "code-review-sidebar",
          "title": "Code Review",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "code-review-sidebar": [
        {
          "id": "code-review-main",
          "name": "Review"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "code-review-main",
        "contents": "Structured review for the active editor (or selection).\n[Review](command:codeReview.runReview)\n[Apply fixes](command:codeReview.applyFixes) (after a review)\n[Authenticate Copilot](command:codeReview.authenticate)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^9.9.0",
    "typescript": "^5.5.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jagannath173/repodocs_poc.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Jagannath173/repodocs_poc/issues"
  },
  "homepage": "https://github.com/Jagannath173/repodocs_poc#readme",
  "dependencies": {
    "diff": "^9.0.0"
  }
}
