{
  "name": "code-review",
  "displayName": "Code Review",
  "description": "Structured Copilot-powered code review in a table view.",
  "version": "1.0.0",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:codeReview.runReview",
    "onCommand:codeReview.applyFixes",
    "onCommand:codeReview.authenticate"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeReview.runReview",
        "title": "Code Review: Review",
        "icon": "$(checklist)"
      },
      {
        "command": "codeReview.applyFixes",
        "title": "Code Review: Apply fixes from last review",
        "icon": "$(wand)"
      },
      {
        "command": "codeReview.authenticate",
        "title": "Code Review: Authenticate Copilot",
        "icon": "$(account)"
      },
      {
        "command": "codeReview.assistant.codeExplanation",
        "title": "Code Review: Assistant - Code Explanation"
      },
      {
        "command": "codeReview.assistant.codeRefactor",
        "title": "Code Review: Assistant - Code Refactor"
      },
      {
        "command": "codeReview.assistant.codeGeneration",
        "title": "Code Review: Assistant - Code Generation"
      },
      {
        "command": "codeReview.assistant.unitTest",
        "title": "Code Review: Assistant - Unit Test"
      },
      {
        "command": "codeReview.assistant.fileWiseUnitTest",
        "title": "Code Review: Assistant - File-wise Unit Test"
      },
      {
        "command": "codeReview.assistant.docstringAddition",
        "title": "Code Review: Assistant - Docstring Addition"
      },
      {
        "command": "codeReview.assistant.commentAddition",
        "title": "Code Review: Assistant - Comment Addition"
      },
      {
        "command": "codeReview.assistant.loggingAddition",
        "title": "Code Review: Assistant - Logging Addition"
      },
      {
        "command": "codeReview.assistant.errorHandling",
        "title": "Code Review: Assistant - Error Handling"
      },
      {
        "command": "codeReview.assistant.testscriptSelfHealing",
        "title": "Code Review: Assistant - Testscript Self Healing"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "code-review-sidebar",
          "title": "Code Review",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "code-review-sidebar": [
        {
          "id": "code-review-main",
          "name": "Review"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "code-review-main",
        "contents": "### Core\n[Review](command:codeReview.runReview)\n[Apply fixes](command:codeReview.applyFixes)\n[Authenticate Copilot](command:codeReview.authenticate)\n\n### Assistant Endpoints\n[Code explanation](command:codeReview.assistant.codeExplanation)\n[Code refactor](command:codeReview.assistant.codeRefactor)\n[Code generation](command:codeReview.assistant.codeGeneration)\n[Unit test](command:codeReview.assistant.unitTest)\n[File-wise unit test](command:codeReview.assistant.fileWiseUnitTest)\n[Docstring addition](command:codeReview.assistant.docstringAddition)\n[Comment addition](command:codeReview.assistant.commentAddition)\n[Logging addition](command:codeReview.assistant.loggingAddition)\n[Error handling](command:codeReview.assistant.errorHandling)\n[Testscript self healing](command:codeReview.assistant.testscriptSelfHealing)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^9.9.0",
    "typescript": "^5.5.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jagannath173/repodocs_poc.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Jagannath173/repodocs_poc/issues"
  },
  "homepage": "https://github.com/Jagannath173/repodocs_poc#readme",
  "dependencies": {
    "diff": "^9.0.0"
  }
}
